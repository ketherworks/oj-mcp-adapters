{
  "name": "oj-mcp-adapters",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "build": "tsc -b",
    "postbuild": "node packages/luogu/scripts/ensure-cli-mode.mjs",
