{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "account": {
      "additionalProperties": false,
      "properties": {
        "accountId": {
          "minLength": 1,
          "type": "string"
        },
        "displayName": {
          "minLength": 1,
          "type": "string"
        },
        "site": {
          "enum": [
            "global",
            "cn"
          ],
          "type": "string"
        }
      },
      "required": [
        "accountId",
        "displayName"
      ],
      "type": "object"
    },
    "actionLabel": {
      "minLength": 1,
      "type": "string"
    },
    "attemptId": {
      "minLength": 1,
      "type": "string"
    },
    "codeArtifactId": {
      "minLength": 1,
      "type": "string"
    },
    "codeBytes": {
      "maximum": 9007199254740991,
      "minimum": 0,
      "type": "integer"
    },
    "codeSha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "expiresAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
      "type": "string"
    },
    "fileLabel": {
      "minLength": 1,
      "type": "string"
    },
    "intentId": {
      "minLength": 1,
      "type": "string"
    },
    "languageKey": {
      "minLength": 1,
      "type": "string"
    },
    "localRunSummary": {
      "additionalProperties": false,
      "properties": {
        "codeSha256": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "runId": {
          "minLength": 1,
          "type": "string"
        },
        "verdict": {
          "enum": [
            "queued",
            "judging",
            "accepted",
            "wrong_answer",
            "compile_error",
            "runtime_error",
            "time_limit",
            "memory_limit",
            "output_limit",
            "idleness_limit",
            "security_violation",
            "partial",
            "skipped",
            "unknown"
          ],
          "type": "string"
        }
      },
      "required": [
        "runId",
        "verdict",
        "codeSha256"
      ],
      "type": "object"
    },
    "platformLanguageId": {
      "minLength": 1,
      "type": "string"
    },
    "problem": {
      "additionalProperties": false,
      "properties": {
        "canonicalId": {
          "minLength": 1,
          "type": "string"
        },
        "contest": {
          "additionalProperties": false,
          "properties": {
            "index": {
              "minLength": 1,
              "type": "string"
            },
            "nativeId": {
              "minLength": 1,
              "type": "string"
            }
          },
          "required": [
            "nativeId"
          ],
          "type": "object"
        },
        "nativeId": {
          "minLength": 1,
          "type": "string"
        },
        "platform": {
          "enum": [
            "luogu",
            "leetcode",
            "nowcoder",
            "codeforces",
            "atcoder"
          ],
          "type": "string"
        },
        "schemaVersion": {
          "const": "oj.problem-ref/v1",
          "type": "string"
        },
        "site": {
          "enum": [
            "global",
            "cn"
          ],
          "type": "string"
        },
        "source": {
          "additionalProperties": false,
          "properties": {
            "adapterId": {
              "minLength": 1,
              "type": "string"
            },
            "adapterVersion": {
              "minLength": 1,
              "type": "string"
            },
            "confidence": {
              "enum": [
                "authoritative",
                "derived",
                "user_supplied"
              ],
              "type": "string"
            },
            "etag": {
              "minLength": 1,
              "type": "string"
            },
            "fetchedAt": {
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
              "type": "string"
            },
            "kind": {
              "enum": [
                "official_api",
                "official_open_platform",
                "page_adapter",
                "browser_companion",
                "community_adapter",
                "manual"
              ],
              "type": "string"
            },
            "rawRef": {
              "minLength": 1,
              "type": "string"
            },
            "sourceUrl": {
              "format": "uri",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "adapterId",
            "adapterVersion",
            "fetchedAt",
            "sourceUrl",
            "confidence"
          ],
          "type": "object"
        },
        "url": {
          "format": "uri",
          "type": "string"
        }
      },
      "required": [
        "schemaVersion",
        "platform",
        "nativeId",
        "canonicalId",
        "url",
        "source"
      ],
      "type": "object"
    },
    "providerId": {
      "minLength": 1,
      "type": "string"
    },
    "schemaVersion": {
      "const": "oj.submit-preview/v1",
      "type": "string"
    },
    "sourceWasDirty": {
      "type": "boolean"
    },
    "submissionOperationId": {
      "minLength": 1,
      "type": "string"
    },
    "warnings": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "schemaVersion",
    "intentId",
    "submissionOperationId",
    "expiresAt",
    "attemptId",
    "providerId",
    "problem",
    "account",
    "languageKey",
    "platformLanguageId",
    "codeArtifactId",
    "fileLabel",
    "sourceWasDirty",
    "codeSha256",
    "codeBytes",
    "warnings",
    "actionLabel"
  ],
  "type": "object"
}
