{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "checkedAt": {
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
      "type": "string"
    },
    "latencyMs": {
      "minimum": 0,
      "type": "number"
    },
    "layers": {
      "additionalProperties": false,
      "properties": {
        "auth": {
          "enum": [
            "not_required",
            "valid",
            "expired",
            "missing",
            "challenge"
          ],
          "type": "string"
        },
        "protocol": {
          "enum": [
            "pass",
            "fail"
          ],
          "type": "string"
        },
        "schema": {
          "enum": [
            "pass",
            "drift",
            "unknown"
          ],
          "type": "string"
        },
        "transport": {
          "enum": [
            "pass",
            "fail"
          ],
          "type": "string"
        },
        "upstream": {
          "enum": [
            "pass",
            "timeout",
            "rate_limited",
            "blocked",
            "fail"
          ],
          "type": "string"
        }
      },
      "required": [
        "transport",
        "protocol",
        "schema",
        "auth",
        "upstream"
      ],
      "type": "object"
    },
    "message": {
      "minLength": 1,
      "type": "string"
    },
    "overall": {
      "enum": [
        "healthy",
        "degraded",
        "unavailable",
        "auth_required"
      ],
      "type": "string"
    },
    "platform": {
      "enum": [
        "luogu",
        "leetcode",
        "nowcoder",
        "codeforces",
        "atcoder"
      ],
      "type": "string"
    },
    "providerId": {
      "minLength": 1,
      "type": "string"
    },
    "retryAfterMs": {
      "minimum": 0,
      "type": "number"
    },
    "schemaVersion": {
      "const": "oj.provider-health/v1",
      "type": "string"
    }
  },
  "required": [
    "schemaVersion",
    "providerId",
    "platform",
    "checkedAt",
    "overall",
    "layers",
    "message"
  ],
  "type": "object"
}
