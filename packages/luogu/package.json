{
  "name": "@kaiserunix/luogu-mcp-server",
  "version": "0.1.0",
  "description": "Anonymous read-only Luogu adapter for the shared OJ MCP contracts.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "luogu-mcp-server": "dist/index.js"
  },
  "files": ["dist", "wrangler.jsonc", "README.md", "LICENSE", "THIRD_PARTY_NOTICES.md"],
  "scripts": {
    "build": "tsc -b && node scripts/ensure-cli-mode.mjs",
    "clean": "node scripts/clean.mjs",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "node scripts/check-publish-platform.mjs",
    "pretest": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run --config vitest.config.ts test"
  },
  "dependencies": {
    "@kaiserunix/oj-mcp-contracts": "0.1.0",
    "@kaiserunix/oj-mcp-server-common": "0.1.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT"
}
